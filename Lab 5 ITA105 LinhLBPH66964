import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from statsmodels.tsa.seasonal import seasonal_decompose

# Cấu hình giao diện biểu đồ
sns.set_theme(style="white")
plt.rcParams['figure.figsize'] = (14, 10)

# 1. Đọc dữ liệu và xử lý thời gian
df = pd.read_csv('ITA105_Lab_5_Production.csv')
df['week_start'] = pd.to_datetime(df['week_start'])
df.set_index('week_start', inplace=True)

# 2. Kiểm tra và điền giá trị thiếu (Missing values)
# Đối với sản xuất, dùng nội suy (interpolation) là cách chính xác nhất để giữ được dòng chảy dữ liệu
print("Số lượng giá trị thiếu trước khi xử lý:\n", df.isnull().sum())
df['production'] = df['production'].interpolate(method='time')

# 3. Tạo các đặc trưng thời gian
df['tuan'] = df.index.isocalendar().week
df['quy'] = df.index.quarter
df['nam'] = df.index.year

# 4. Phát hiện xu hướng (Trend) dài hạn bằng Rolling Mean
# Sử dụng cửa sổ 12 tuần (khoảng 1 quý) để lọc nhiễu
df['xu_huong_rolling'] = df['production'].rolling(window=12).mean()

plt.figure(figsize=(14, 6))
plt.plot(df.index, df['production'], label='Sản lượng thực tế', color='gray', alpha=0.4)
plt.plot(df.index, df['xu_huong_rolling'], label='Xu hướng trung bình (12 tuần)', color='blue', linewidth=2)
plt.title('XU HƯỚNG SẢN XUẤT CÔNG NGHIỆP', fontsize=14, fontweight='bold')
plt.xlabel('Thời gian')
plt.ylabel('Sản lượng')
plt.legend()
plt.show()

# 5. Phân tích Seasonality theo quý và vẽ biểu đồ Decomposition
# Vì dữ liệu theo tuần, một quý có khoảng 13 tuần nên ta đặt period=13
ket_qua_decom = seasonal_decompose(df['production'].dropna(), model='additive', period=13)

# Vẽ biểu đồ phân rã (Trend + Seasonality + Residuals)
fig = ket_qua_decom.plot()
axes = fig.get_axes()

# Việt hóa các tiêu đề trong biểu đồ decomposition
axes[0].set_title('PHÂN RÃ CHUỖI THỜI GIAN SẢN XUẤT', fontsize=16, fontweight='bold')
axes[0].set_ylabel('Dữ liệu gốc')
axes[1].set_ylabel('Xu hướng (Trend)')
axes[2].set_ylabel('Mùa vụ (Seasonality)')
axes[3].set_ylabel('Nhiễu (Residuals)')

for ax in axes:
    ax.set_xlabel('Thời gian')

plt.tight_layout()
plt.show()

# Hiển thị đặc trưng theo quý để phân tích thêm (tùy chọn)
print("\nSản lượng trung bình theo từng Quý:")
print(df.groupby('quy')['production'].mean())

plt.show()
