import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from statsmodels.tsa.seasonal import seasonal_decompose

# Thiết lập phong cách cho biểu đồ
sns.set_theme(style="whitegrid")
plt.rcParams['figure.figsize'] = (14, 10)

# 1. Đọc và xử lý dữ liệu
df = pd.read_csv('ITA105_Lab_5_Supermarket.csv')

# Chuyển cột ngày về kiểu thời gian và đặt làm chỉ mục (index)
df['date'] = pd.to_datetime(df['date'])
df.set_index('date', inplace=True)

# 2. Xử lý giá trị còn thiếu
# Sử dụng phương pháp nội suy (Interpolation) để điền các giá trị trống
df['revenue'] = df['revenue'].interpolate(method='linear')
df['revenue'] = df['revenue'].ffill().bfill()

# 3. Tạo các đặc trưng mới
df['nam'] = df.index.year
df['thang'] = df.index.month
df['quy'] = df.index.quarter
df['thu_trong_tuan'] = df.index.dayofweek
df['cuoi_tuan'] = df.index.dayofweek.map(lambda x: 1 if x >= 5 else 0)

# 4. Vẽ biểu đồ tổng doanh thu
# Gom nhóm dữ liệu theo tháng (M) và tuần (W)
doanh_thu_thang = df['revenue'].resample('M').sum()
doanh_thu_tuan = df['revenue'].resample('W').sum()

fig, ax = plt.subplots(2, 1)

# Biểu đồ doanh thu theo tháng
doanh_thu_thang.plot(ax=ax[0], color='#1f77b4', marker='o', linewidth=2)
ax[0].set_title('TỔNG DOANH THU THEO THÁNG', fontsize=14, fontweight='bold')
ax[0].set_xlabel('Thời gian')
ax[0].set_ylabel('Doanh thu')

# Biểu đồ doanh thu theo tuần
doanh_thu_tuan.plot(ax=ax[1], color='#2ca02c', linewidth=1.5)
ax[1].set_title('TỔNG DOANH THU THEO TUẦN', fontsize=14, fontweight='bold')
ax[1].set_xlabel('Thời gian')
ax[1].set_ylabel('Doanh thu')

plt.tight_layout()
plt.show()

# 5. Phân tích Xu hướng và Mùa vụ
# Sử dụng decomposition để phân tách các thành phần của chuỗi thời gian
ket_qua = seasonal_decompose(df['revenue'], model='additive', period=30)

# Vẽ biểu đồ phân tách với ngôn ngữ tiếng Việt
fig = ket_qua.plot()
axes = fig.get_axes()
axes[0].set_title('PHÂN TÍCH XU HƯỚNG VÀ MÙA VỤ', fontsize=16, fontweight='bold')
axes[0].set_ylabel('Gốc')
axes[1].set_ylabel('Xu hướng')
axes[2].set_ylabel('Mùa vụ')
axes[3].set_ylabel('Nhiễu')
for ax in axes:
    ax.set_xlabel('Thời gian')


