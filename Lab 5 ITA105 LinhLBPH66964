import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from statsmodels.tsa.seasonal import seasonal_decompose

# Thiết lập phong cách biểu đồ
sns.set_theme(style="whitegrid")
plt.rcParams['figure.figsize'] = (14, 8)

# 1. Đọc dữ liệu và đặt tần suất hourly
df = pd.read_csv('ITA105_Lab_5_Web_traffic.csv')
df['datetime'] = pd.to_datetime(df['datetime'])
df.set_index('datetime', inplace=True)

# Đảm bảo dữ liệu có tần suất đầy đủ theo giờ (hourly)
df = df.asfreq('H')

# 2. Xử lý dữ liệu thiếu bằng nội suy tuyến tính (Linear Interpolation)
print("Số lượng giá trị thiếu trước khi xử lý:", df['visits'].isnull().sum())
df['visits'] = df['visits'].interpolate(method='linear')

# 3. Tạo biến đặc trưng: giờ và ngày trong tuần
df['gio'] = df.index.hour
df['thu_trong_tuan'] = df.index.dayofweek # 0 là Thứ 2, 6 là Chủ nhật

# 4. Vẽ biểu đồ lưu lượng theo giờ để tìm đỉnh (peak) và đáy (trough)
doanh_thu_theo_gio = df.groupby('gio')['visits'].mean()

plt.figure(figsize=(12, 6))
doanh_thu_theo_gio.plot(kind='line', marker='o', color='red', linewidth=2)
plt.title('LƯU LƯỢNG TRUY CẬP TRUNG BÌNH THEO GIỜ TRONG NGÀY', fontsize=14, fontweight='bold')
plt.xlabel('Giờ trong ngày')
plt.ylabel('Số lượt truy cập trung bình')
plt.xticks(range(0, 24))
plt.grid(True)
plt.show()

# 5. Phân tích Seasonality (Mùa vụ) hàng ngày và hàng tuần
# Mùa vụ hàng ngày (period=24 giờ)
phan_tach_ngay = seasonal_decompose(df['visits'], model='additive', period=24)

# Mùa vụ hàng tuần (period=24*7 giờ)
phan_tach_tuan = seasonal_decompose(df['visits'], model='additive', period=24*7)

# Vẽ biểu đồ mùa vụ
fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))

ax1.plot(phan_tach_ngay.seasonal[:72], color='purple') # Vẽ 3 ngày để thấy rõ chu kỳ
ax1.set_title('TÍNH MÙA VỤ THEO NGÀY (Chu kỳ 24h)', fontsize=12, fontweight='bold')

ax2.plot(phan_tach_tuan.seasonal[:24*14], color='orange') # Vẽ 2 tuần để thấy rõ chu kỳ
ax2.set_title('TÍNH MÙA VỤ THEO TUẦN (Chu kỳ 168h)', fontsize=12, fontweight='bold')

plt.tight_layout()
plt.show()


