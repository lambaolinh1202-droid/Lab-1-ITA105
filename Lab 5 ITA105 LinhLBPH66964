import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from statsmodels.tsa.seasonal import seasonal_decompose

# Thiết lập giao diện biểu đồ
sns.set_theme(style="darkgrid")
plt.rcParams['figure.figsize'] = (14, 10)

# 1. Đọc dữ liệu và xử lý thời gian
df = pd.read_csv('ITA105_Lab_5_Stock.csv')
df['date'] = pd.to_datetime(df['date'])
df.set_index('date', inplace=True)

# 2. Xử lý dữ liệu thiếu (ngày nghỉ giao dịch)
# Sử dụng Forward Fill để lấy giá đóng cửa ngày gần nhất điền vào ngày trống
df = df.asfreq('D') # Đảm bảo có đủ tất cả các ngày trong năm
print("Số lượng giá trị thiếu (do ngày nghỉ):", df['close_price'].isnull().sum())
df['close_price'] = df['close_price'].ffill()

# 3. Vẽ biểu đồ giá đóng cửa (Line plot)
plt.figure(figsize=(14, 6))
plt.plot(df.index, df['close_price'], label='Giá đóng cửa thực tế', color='blue', alpha=0.6)
plt.title('BIỂU ĐỒ GIÁ CỔ PHIẾU', fontsize=14, fontweight='bold')
plt.xlabel('Thời gian')
plt.ylabel('Giá (USD)')
plt.legend()
plt.show()

# 4. Tạo Rolling Mean 7 ngày và 30 ngày để nhận diện xu hướng (Trend)
df['MA7'] = df['close_price'].rolling(window=7).mean()
df['MA30'] = df['close_price'].rolling(window=30).mean()

plt.figure(figsize=(14, 7))
plt.plot(df.index, df['close_price'], label='Giá gốc', alpha=0.3, color='gray')
plt.plot(df.index, df['MA7'], label='Xu hướng 7 ngày (Ngắn hạn)', color='orange', linewidth=2)
plt.plot(df.index, df['MA30'], label='Xu hướng 30 ngày (Dài hạn)', color='red', linewidth=2)
plt.title('NHẬN DIỆN XU HƯỚNG BẰNG TRUNG BÌNH TRƯỢT (ROLLING MEAN)', fontsize=14, fontweight='bold')
plt.xlabel('Thời gian')
plt.ylabel('Giá')
plt.legend()
plt.show()

# 5. Phân tích Seasonality theo tháng (Chu kỳ 30 ngày)
phan_tach = seasonal_decompose(df['close_price'], model='additive', period=30)

fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10))

# Vẽ thành phần mùa vụ (Seasonality)
ax1.plot(phan_tach.seasonal[:180], color='green') # Vẽ khoảng 6 tháng để xem pattern
ax1.set_title('PHÂN TÍCH TÍNH MÙA VỤ THEO THÁNG', fontsize=12, fontweight='bold')
ax1.set_ylabel('Giá trị biến động')

# Vẽ thành phần xu hướng (Trend)
ax2.plot(phan_tach.trend, color='darkred')
ax2.set_title('XU HƯỚNG DÀI HẠN (DECOMPOSED TREND)', fontsize=12, fontweight='bold')
ax2.set_ylabel('Giá trị xu hướng')

plt.tight_layout()
plt.show()


