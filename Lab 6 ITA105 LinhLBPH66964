import cv2
import numpy as np
import matplotlib.pyplot as plt
import random
import glob

# 1. Tự động quét toàn bộ ảnh nội thất Bao Bao đã up lên
# (Code sẽ lấy tất cả file có đuôi jpg, png, jpeg)
image_files = glob.glob("*.png") + glob.glob("*.jpg") + glob.glob("*.jpeg")

# Chị Pao Pao thêm dòng này để code tự chọn TẤM ẢNH ĐẦU TIÊN làm mẫu.
# Bao Bao có thể sửa số [0] thành [1], [2]... để chọn ảnh khác nhé.
if len(image_files) > 0:
    # Lọc bỏ các ảnh cũ của bài trước nếu có (anh xe, trai cay...)
    furniture_files = [f for f in image_files if 'trai cay' not in f and 'anh xe' not in f and 'image' not in f]

    if len(furniture_files) > 0:
        # Bốc thăm lấy tấm ảnh đầu tiên
        chosen_file = furniture_files[0]
        print(f">>> Chị Pao Pao đã bốc thăm được tấm ảnh: {chosen_file}")
    else:
        # Nếu không lọc được tên, thì lấy đại tấm đầu tiên trong list tổng
        chosen_file = image_files[0]
        print(f">>> Code tự chọn tấm ảnh đầu tiên trong danh sách: {chosen_file}")
else:
    chosen_file = None

def apply_augmentation(image):
    # --- THỰC HIỆN YÊU CẦU BÀI 4 ---

    # A. Resize về 224x224
    img = cv2.resize(image, (224, 224))

    # B. Augmentation: Xoay, Lật, Độ sáng
    # Xoay ngẫu nhiên +/- 15 độ
    angle = random.uniform(-15, 15)
    M = cv2.getRotationMatrix2D((112, 112), angle, 1.0)
    img_augmented = cv2.warpAffine(img, M, (224, 224))

    # Lật ngang ngẫu nhiên (Horizontal Flip)
    if random.random() > 0.5:
        img_augmented = cv2.flip(img_augmented, 1)

    # Thay đổi độ sáng ngẫu nhiên +/- 20%
    brightness_factor = random.uniform(0.8, 1.2)
    img_augmented = np.clip(img_augmented * brightness_factor, 0, 255).astype(np.uint8)

    # C. Chuyển từ RGB sang Grayscale (Trắng đen)
    img_gray = cv2.cvtColor(img_augmented, cv2.COLOR_BGR2GRAY)

    # D. Chuẩn hóa pixel về [0, 1]
    img_normalized = img_gray.astype(np.float32) / 255.0

    return img, img_normalized # Trả về ảnh gốc (đã resize) và ảnh đã xử lý

# 2. Xử lý và hiển thị kết quả
if chosen_file:
    # Đọc ảnh gốc
    original_raw = cv2.imread(chosen_file)

    if original_raw is not None:
        # Lấy bản Resize làm gốc để hiển thị
        img_resized, _ = apply_augmentation(original_raw)

        # Tạo 3 bản augmentation khác nhau (do random nên sẽ khác nhau)
        augmented_versions = []
        for _ in range(3):
            _, processed_img = apply_augmentation(original_raw)
            augmented_versions.append(processed_img)

        # Hiển thị 1 ảnh gốc và 3 ảnh biến hóa chuyên nghiệp
        fig, axes = plt.subplots(1, 4, figsize=(20, 6))

        # Tiêu đề chuyên nghiệp để nộp thầy
        fig.suptitle('KET QUA XU LY VA AUGMENTATION ANH NOI THAT (GRAYSCALE + RANDOM)',
                     fontsize=16, fontweight='bold', color='#191970')

        # 1. Hiển thị ảnh gốc (Màu)
        axes[0].imshow(cv2.cvtColor(img_resized, cv2.COLOR_BGR2RGB))
        axes[0].set_title("Original (224x224 RGB)", fontsize=11)
        axes[0].axis('off')

        # 2. Hiển thị 3 bản biến hóa (Trắng đen, đã chuẩn hóa)
        for i in range(3):
            axes[i+1].imshow(augmented_versions[i], cmap='gray')
            axes[i+1].set_title(f"Augmented Version {i+1}\n(Gray + [0-1])", fontsize=10)
            axes[i+1].axis('off')

        plt.tight_layout(rect=[0, 0.03, 1, 0.95])
        plt.show()
        print(">>> Hoàn thành bài 4 xuất sắc! Dữ liệu đã sẵn sàng để nộp thầy.")
    else:
        print(f" code không đọc được file {chosen_file}. Em kiểm tra lại xem ảnh có bị lỗi không nhé!")
else:
    print(" không thấy ảnh nội thất nào trong ngăn Files hết. !")
