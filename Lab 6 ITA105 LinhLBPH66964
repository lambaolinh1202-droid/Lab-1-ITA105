import cv2
import numpy as np
import matplotlib.pyplot as plt
import glob

# 1. Tự động quét tất cả ảnh em đã up lên Colab
danh_sach_anh = glob.glob("*.png") + glob.glob("*.jpg") + glob.glob("*.jpeg")
danh_sach_anh = sorted(danh_sach_anh)[:5] # Lấy đúng 5 tấm đầu tiên

if len(danh_sach_anh) == 0:
    print("Bao Bao ơi, chị chưa thấy ảnh đâu hết, em kiểm tra lại bước kéo thả nha!")
else:
    # 2. Bắt đầu "phù phép" từng tấm một
    original_images = []
    processed_images = []

    for path in danh_sach_anh:
        img = cv2.imread(path)
        # Resize
        img_res = cv2.resize(img, (224, 224))

        # Augmentation (Xoay, Lật, Sáng)
        M = cv2.getRotationMatrix2D((112, 112), np.random.uniform(-15, 15), 1.0)
        img_aug = cv2.warpAffine(img_res, M, (224, 224))
        if np.random.rand() > 0.5: img_aug = cv2.flip(img_aug, 1)
        img_aug = np.clip(img_aug * np.random.uniform(0.8, 1.2), 0, 255).astype(np.uint8)

        # Grayscale & Chuẩn hóa [0-1]
        img_gray = cv2.cvtColor(img_aug, cv2.COLOR_BGR2GRAY)
        img_norm = img_gray.astype(np.float32) / 255.0

        original_images.append(img_res)
        processed_images.append(img_norm)

    # 3. Hiển thị kết quả "Wao"
    fig, axes = plt.subplots(2, 5, figsize=(20, 8))
    for i in range(len(original_images)):
        axes[0, i].imshow(cv2.cvtColor(original_images[i], cv2.COLOR_BGR2RGB))
        axes[0, i].set_title(f"Gốc {i+1}")
        axes[0, i].axis('off')

        axes[1, i].imshow(processed_images[i], cmap='gray')
        axes[1, i].set_title(f"Biến hóa {i+1}")
        axes[1, i].axis('off')
    plt.show()


