import cv2
import numpy as np
import matplotlib.pyplot as plt
import random

# 1. Danh sách file ảnh trái cây Bao Bao đã up
fruit_files = [
    'trai cay 1.jpg',
    'trai cay 2.jpg',
    'trai cay 3.jpg',
    'trai cay 4.jpg',
    'trai cay 5.jpg'
]

def apply_augmentation(image):
    # --- THỰC HIỆN YÊU CẦU BÀI 3 ---

    # A. Resize về 224x224
    img = cv2.resize(image, (224, 224))

    # B. Random Crop & Zoom (Cắt ngẫu nhiên và phóng to)
    h, w = img.shape[:2]
    # Cắt ngẫu nhiên từ 70% đến 90% diện tích ảnh gốc
    crop_size = random.randint(160, 200)
    top = random.randint(0, h - crop_size)
    left = random.randint(0, w - crop_size)
    img = img[top:top+crop_size, left:left+crop_size]
    img = cv2.resize(img, (224, 224)) # Zoom lại về kích thước chuẩn

    # C. Flip (Lật ngang/dọc ngẫu nhiên)
    if random.random() > 0.5:
        img = cv2.flip(img, 1) # Lật ngang
    if random.random() > 0.5:
        img = cv2.flip(img, 0) # Lật dọc

    # D. Rotation (Xoay ngẫu nhiên +/- 30 độ)
    angle = random.uniform(-30, 30)
    M = cv2.getRotationMatrix2D((112, 112), angle, 1.0)
    img = cv2.warpAffine(img, M, (224, 224))

    # E. Chuẩn hóa pixel về [0, 1]
    img_normalized = img.astype(np.float32) / 255.0
    return img_normalized

# 2. Tạo 9 mẫu biến hóa từ danh sách ảnh gốc
augmented_samples = []
for _ in range(9):
    # Chọn ngẫu nhiên 1 trong 5 ảnh gốc để biến hóa
    chosen_file = random.choice(fruit_files)
    raw_img = cv2.imread(chosen_file)
    if raw_img is not None:
        processed = apply_augmentation(raw_img)
        augmented_samples.append(processed)

# 3. Hiển thị Grid 3x3
if len(augmented_samples) == 9:
    fig, axes = plt.subplots(3, 3, figsize=(12, 12))
    fig.suptitle('KET QUA AUGMENTATION DU LIEU NONG SAN (GRID 3X3)',
                 fontsize=16, fontweight='bold', color='#1a5276')

    for i, ax in enumerate(axes.flat):
        # Chuyển từ BGR (OpenCV) sang RGB (Matplotlib)
        img_rgb = cv2.cvtColor(augmented_samples[i], cv2.COLOR_BGR2RGB)
        ax.imshow(img_rgb)
        ax.set_title(f"Sample {i+1} (Zoom/Flip/Rotate)", fontsize=10)
        ax.axis('off')

    plt.tight_layout(rect=[0, 0.03, 1, 0.95])
    plt.show()
    print(">>> Hoàn thành Grid 3x3 cho dữ liệu nông sản.")
    print(">>> Dữ liệu đã được chuẩn hóa về khoảng [0, 1].")


