import cv2
import numpy as np
import matplotlib.pyplot as plt

# 1. Danh sách tên file ảnh xe Bao Bao vừa up
image_files = [
    'anh xe 1.jpg',
    'anh xe 2.jpg',
    'anh xe 3.jpg',
    'anh xe 4.jpg',
    'anh xe 5.jpg'
]

def add_gaussian_noise(image):
    # Hàm thêm nhiễu hạt Gaussian
    row, col, ch = image.shape
    mean = 0
    sigma = 15 # Độ nhiễu hạt
    gauss = np.random.normal(mean, sigma, (row, col, ch))
    noisy = image + gauss
    return np.clip(noisy, 0, 255).astype(np.uint8)

original_resized = []
processed_images = []

for file_name in image_files:
    # Đọc ảnh
    img = cv2.imread(file_name)
    if img is None:
        continue

    # --- THỰC HIỆN YÊU CẦU BÀI 2 ---

    # 1. Resize về 224x224
    img_res = cv2.resize(img, (224, 224))

    # 2. Augmentation: Gaussian noise + Brightness + Rotate
    # Thêm nhiễu Gaussian
    img_aug = add_gaussian_noise(img_res)

    # Chỉnh độ sáng +/- 15%
    brightness_factor = np.random.uniform(0.85, 1.15)
    img_aug = np.clip(img_aug * brightness_factor, 0, 255).astype(np.uint8)

    # Xoay +/- 10 độ
    M = cv2.getRotationMatrix2D((112, 112), np.random.uniform(-10, 10), 1.0)
    img_aug = cv2.warpAffine(img_aug, M, (224, 224))

    # 3. Chuyển sang Grayscale (Để giảm số kênh theo tùy chọn)
    img_gray = cv2.cvtColor(img_aug, cv2.COLOR_BGR2GRAY)

    # 4. Chuẩn hóa pixel về [0, 1]
    img_norm = img_gray.astype(np.float32) / 255.0

    original_resized.append(img_res)
    processed_images.append(img_norm)

# --- HIỂN THỊ KẾT QUẢ SO SÁNH ---
fig, axes = plt.subplots(2, 5, figsize=(20, 8))
fig.suptitle('BÀI 2: XỬ LÝ ẢNH XE (NOISE + BRIGHTNESS + ROTATE)', fontsize=16, fontweight='bold')

for i in range(len(original_resized)):
    # Hàng 1: Xe gốc (RGB)
    axes[0, i].imshow(cv2.cvtColor(original_resized[i], cv2.COLOR_BGR2RGB))
    axes[0, i].set_title(f"Xe gốc {i+1}")
    axes[0, i].axis('off')

    # Hàng 2: Xe biến hóa (Grayscale, Noise, [0-1])
    axes[1, i].imshow(processed_images[i], cmap='gray')
    axes[1, i].set_title(f"Biến hóa {i+1}")
    axes[1, i].axis('off')

plt.tight_layout()
plt.show()


