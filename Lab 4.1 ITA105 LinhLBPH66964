    import pandas as pd
import numpy as np
import re
import nltk
import os
from sklearn.preprocessing import LabelEncoder
from sklearn.feature_extraction.text import TfidfVectorizer
from gensim.models import Word2Vec

# Tải dữ liệu xử lý ngôn ngữ
nltk.download('punkt')
nltk.download('punkt_tab')
from nltk.tokenize import word_tokenize

# --- BƯỚC 1: NẠP VÀ LÀM SẠCH DỮ LIỆU ---
file_path = 'ITA105_Lab_4_Album_reviews.csv'

if not os.path.exists(file_path):
    print("❌ Bé ơi, máy chưa thấy file Album_reviews! Bé nhớ Upload vào cột bên trái nhé.")
else:
    df = pd.read_csv(file_path)

    # Làm sạch: Xóa dòng trống nếu có
    df = df.dropna(subset=['genre', 'review_text']).reset_index(drop=True)
    print("1. Đã nạp dữ liệu Album và xử lý dòng trống thành công!")

    # --- BƯỚC 2: MÃ HÓA CỘT CATEGORICAL ---
    le = LabelEncoder()
    df['genre_encoded'] = le.fit_transform(df['genre'].astype(str))
    df['platform_encoded'] = le.fit_transform(df['platform'].astype(str))
    print("2. Đã mã hóa xong cột 'genre' và 'platform'.")

    # --- BƯỚC 3: TIỀN XỬ LÝ VĂN BẢN ---
    def preprocess_album_review(text):
        text = str(text).lower() # Viết thường
        text = re.sub(r'[^\w\s]', '', text) # Xóa dấu câu
        tokens = word_tokenize(text) # Tách từ
        # Loại bỏ Stop words âm nhạc cơ bản
        stop_words = ['và', 'là', 'nhưng', 'có', 'những', 'của', 'với', 'cho', 'một', 'này']
        tokens = [t for t in tokens if t not in stop_words]
        return tokens

    df['tokens'] = df['review_text'].apply(preprocess_album_review)
    df['clean_review'] = df['tokens'].apply(lambda x: " ".join(x))
    print("3. Đã tiền xử lý văn bản (Lowercase, Tokenize, Stop words).")

    # --- BƯỚC 4: TẠO MA TRẬN TF-IDF ---
    tfidf = TfidfVectorizer()
    tfidf_matrix = tfidf.fit_transform(df['clean_review'])
    print(f"4. Đã tạo ma trận TF-IDF. Kích thước: {tfidf_matrix.shape}")

    # --- BƯỚC 5: WORD2VEC VÀ TÌM TỪ GẦN NGHĨA ---
    w2v_model = Word2Vec(sentences=df['tokens'], vector_size=100, window=5, min_count=1, workers=4)

    target = 'sáng_tạo'
    # Kiểm tra cả từ đơn và từ ghép
    search_word = 'sáng'
    if 'sáng_tạo' in w2v_model.wv.key_to_index: search_word = 'sáng_tạo'

    print(f"\n5. KẾT QUẢ TÌM 5 TỪ GẦN NGHĨA VỚI '{search_word}':")
    if search_word in w2v_model.wv.key_to_index:
        sims = w2v_model.wv.most_similar(search_word, topn=5)
        for word, score in sims:
            print(f"   - {word}: {score:.4f}")
    else:
        print(f"   - Từ '{search_word}' chưa đủ dữ liệu để học, các từ máy đã biết là:")
        print(f"   - {w2v_model.wv.index_to_key[:5]}")

    # --- BƯỚC 6: SO SÁNH VÀ NHẬN XÉT ---
    print("\n" + "="*60)
    print("6. SO SÁNH KHẢ NĂNG BIỂU DIỄN NỘI DUNG:")
    print("- TF-IDF: Biểu diễn văn bản dưới dạng TẦN SUẤT từ. Phù hợp để")
    print("  tìm các từ khóa mang tính đặc trưng của album (tên ca sĩ, thể loại).")
    print("- Word2Vec: Biểu diễn văn bản dưới dạng NGỮ NGHĨA. Nó hiểu được các")
    print("  từ như 'sáng tạo', 'độc đáo', 'mới mẻ' có sự tương đồng về ý nghĩa.")
    print("\nNHẬN XÉT:")
    print("Word2Vec mang lại cái nhìn sâu sắc hơn về cảm xúc và phong cách nghệ thuật")
    print("trong review, trong khi TF-IDF tập trung vào các từ ngữ cụ thể xuất hiện.")
    print("="*60)
    print("\n🎉 CHÚC MỪNG BÉ LINH ĐÃ HOÀN THÀNH TẤT CẢ BÀI LAB 4!")
