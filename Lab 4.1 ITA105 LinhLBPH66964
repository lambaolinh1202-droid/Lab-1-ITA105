import numpy as np
import re
import nltk
import os
from sklearn.preprocessing import LabelEncoder
from sklearn.feature_extraction.text import TfidfVectorizer
from gensim.models import Word2Vec

# Tải bộ công cụ xử lý ngôn ngữ
nltk.download('punkt')
nltk.download('punkt_tab')
from nltk.tokenize import word_tokenize

# --- BƯỚC 1: NẠP VÀ LÀM SẠCH DỮ LIỆU ---
file_path = 'ITA105_Lab_4_Match_comments.csv'

if not os.path.exists(file_path):
    print("❌ Bé ơi, máy chưa thấy file Match_comments! Bé nhớ Upload vào cột bên trái nhé.")
else:
    df = pd.read_csv(file_path)

    # Xử lý Missing Values: Xóa dòng trống để không bị lỗi Encoding
    df = df.dropna(subset=['team', 'comment_text']).reset_index(drop=True)
    print("1. Đã nạp dữ liệu và làm sạch các dòng trống thành công!")

    # --- BƯỚC 2: MÃ HÓA CỘT CATEGORICAL ---
    le = LabelEncoder()
    df['team_encoded'] = le.fit_transform(df['team'].astype(str))
    df['author_encoded'] = le.fit_transform(df['author'].astype(str))
    print("2. Đã mã hóa xong cột 'team' và 'author' bằng Label Encoding.")

    # --- BƯỚC 3: TIỀN XỬ LÝ VĂN BẢN ---
    def preprocess_football_text(text):
        text = str(text).lower() # Lowercase
        text = re.sub(r'[^\w\s]', '', text) # Xóa dấu câu
        tokens = word_tokenize(text) # Tokenization
        # Stop words cơ bản
        stop_words = ['và', 'là', 'nhưng', 'có', 'những', 'của', 'với', 'cho', 'đội', 'trận']
        tokens = [t for t in tokens if t not in stop_words]
        return tokens

    df['tokens'] = df['comment_text'].apply(preprocess_football_text)
    df['clean_comment'] = df['tokens'].apply(lambda x: " ".join(x))
    print("3. Đã tiền xử lý văn bản (viết thường, tách từ, loại bỏ stop words).")

    # --- BƯỚC 4: TẠO MA TRẬN TF-IDF ---
    tfidf = TfidfVectorizer()
    tfidf_matrix = tfidf.fit_transform(df['clean_comment'])
    print(f"4. Đã tạo ma trận TF-IDF. Kích thước ma trận: {tfidf_matrix.shape}")

    # --- BƯỚC 5: WORD2VEC VÀ TÌM TỪ GẦN NGHĨA ---
    w2v_model = Word2Vec(sentences=df['tokens'], vector_size=100, window=5, min_count=1, workers=4)

    target = 'xuất_sắc' # Word2Vec thường học từ ghép có gạch dưới hoặc từ đơn
    # Kiểm tra cả 2 trường hợp từ đơn và từ ghép
    search_word = 'xuất'
    if 'xuất_sắc' in w2v_model.wv.key_to_index: search_word = 'xuất_sắc'
    elif 'sắc' in w2v_model.wv.key_to_index: search_word = 'sắc'

    print(f"\n5. KẾT QUẢ TÌM 5 TỪ GẦN NGHĨA VỚI TỪ KHÓA TRONG BÌNH LUẬN:")
    try:
        sims = w2v_model.wv.most_similar(search_word, topn=5)
        for word, score in sims:
            print(f"   - {word}: {score:.4f}")
    except:
        # Nếu không tìm thấy đúng từ đó, lấy đại diện vài từ máy đã học được
        print("   - Máy chưa học đủ từ 'xuất sắc', đây là các từ máy học được tốt nhất:")
        print(f"   - {w2v_model.wv.index_to_key[:5]}")

    # --- BƯỚC 6: SO SÁNH KHẢ NĂNG BIỂU DIỄN ---
    print("\n" + "="*60)
    print("6. SO SÁNH KHẢ NĂNG BIỂU DIỄN Ý NGHĨA:")
    print("- TF-IDF: Biểu diễn dựa trên TẦN SUẤT. Nó giúp xác định bình luận nào")
    print("  có chứa các từ độc đáo, nhưng không hiểu được cảm xúc hay ngữ nghĩa.")
    print("- Word2Vec: Biểu diễn dựa trên NGỮ CẢNH. Nó hiểu được các từ như")
    print("  'xuất sắc', 'hay', 'ấn tượng' có mối liên hệ mật thiết với nhau.")
    print("=> Word2Vec biểu diễn ý nghĩa sâu sắc hơn cho các bình luận bóng đá.")
    print("="*60)
    print("\n🎉 XONG BÀI 2 RỒI ĐÓ BÉ LINH ƠI!")



