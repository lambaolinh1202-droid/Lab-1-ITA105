import pandas as pd
import numpy as np
import re
import nltk
import os
from sklearn.preprocessing import LabelEncoder
from sklearn.feature_extraction.text import TfidfVectorizer
from gensim.models import Word2Vec

# Tải bộ công cụ xử lý ngôn ngữ
nltk.download('punkt')
nltk.download('punkt_tab')
from nltk.tokenize import word_tokenize

# --- BƯỚC 1: NẠP VÀ KIỂM TRA MISSING VALUES ---
file_path = 'ITA105_Lab_4_Hotel_reviews.csv'

if not os.path.exists(file_path):
    print("❌ Bé ơi, máy vẫn chưa thấy file! Bé nhớ Upload lại vào cột bên trái nhé.")
else:
    df = pd.read_csv(file_path)
    print("1. KIỂM TRA MISSING VALUES:")
    print(df.isnull().sum())

    # Làm sạch: Xóa dòng trống
    df = df.dropna(subset=['hotel_name', 'review_text']).reset_index(drop=True)
    print(f"\n=> Đã xử lý xong Missing Values. Số dòng còn lại: {len(df)}")

    # --- BƯỚC 2: LABEL ENCODING ---
    le = LabelEncoder()
    df['hotel_name_encoded'] = le.fit_transform(df['hotel_name'].astype(str))
    df['customer_type_encoded'] = le.fit_transform(df['customer_type'].astype(str))
    print("\n2. ĐÃ ENCODING XONG CÁC BIẾN CATEGORICAL (hotel_name, customer_type)")

    # --- BƯỚC 3: TIỀN XỬ LÝ VĂN BẢN ---
    def preprocess_text(text):
        text = str(text).lower() # Lowercase
        text = re.sub(r'[^\w\s]', '', text) # Xóa ký tự đặc biệt
        tokens = word_tokenize(text) # Tokenization
        stop_words = ['và', 'là', 'nhưng', 'có', 'những', 'của', 'với', 'cho', 'cái', 'này']
        return [t for t in tokens if t not in stop_words]

    df['tokens'] = df['review_text'].apply(preprocess_text)
    df['clean_review'] = df['tokens'].apply(lambda x: " ".join(x))
    print("\n3. ĐÃ HOÀN THÀNH TIỀN XỬ LÝ (Lowercase, Tokenize, Stop words)")

    # --- BƯỚC 4: TẠO TF-IDF MATRIX ---
    tfidf = TfidfVectorizer()
    tfidf_matrix = tfidf.fit_transform(df['clean_review'])
    print(f"\n4. TẠO MA TRẬN TF-IDF THÀNH CÔNG. Kích thước: {tfidf_matrix.shape}")

    # --- BƯỚC 5: WORD2VEC VÀ TÌM TỪ GẦN NGHĨA ---
    w2v_model = Word2Vec(sentences=df['tokens'], vector_size=100, window=5, min_count=1, workers=4)

    target = 'sạch' # Trong dữ liệu bé tách từ thường ra từ 'sạch'
    print(f"\n5. KẾT QUẢ TÌM 5 TỪ GẦN NGHĨA VỚI '{target}':")
    if target in w2v_model.wv.key_to_index:
        sims = w2v_model.wv.most_similar(target, topn=5)
        for word, score in sims:
            print(f"   - {word}: {score:.4f}")

    # --- BƯỚC 6: TRẢ LỜI LÝ THUYẾT ---
    print("\n" + "="*50)
    print("6. SO SÁNH TF-IDF VÀ WORD2VEC:")
    print("- Dùng TF-IDF khi: Cần tìm từ khóa quan trọng, dữ liệu ít, cần xử lý nhanh.")
    print("  Ví dụ: Phân loại thư rác, trích xuất đặc trưng văn bản cơ bản.")
    print("- Dùng Word2Vec khi: Cần hiểu ngữ nghĩa và mối quan hệ giữa các từ.")
    print("  Ví dụ: Tìm từ đồng nghĩa, hệ thống gợi ý, chatbot thông minh.")
    print("="*50)
    print("\n🎉 BÀI LAB 1 CỦA BÉ LINH ĐÃ HOÀN TẤT!")



