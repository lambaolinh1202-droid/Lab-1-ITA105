    sns.kdeplot(zscore[col_name], fill=True, color='red')
    plt.title(f'Sau Z-Score (mean=0)')
    
    plt.suptitle(f'So sánh Scaling cho biến: {col_name}', fontsize=15)
    plt.show()

# Gọi hàm vẽ cho từng biến
for col in cols:
    compare_scaling(df, df_minmax, df_zscore, col)



