# BÀI 1: KHÁM PHÁ DỮ LIỆU HOUSING
# ==========================================

import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
from scipy import stats
from google.colab import files

# --- 1. Nạp dữ liệu ---
print("--- Bước 1: Nạp dữ liệu ---")
# Nếu bạn chưa tải file lên, dùng lệnh này:
uploaded = files.upload()
df = pd.read_csv('ITA105_Lab_2_Housing.csv')

print(f"Kích thước (shape): {df.shape}")
print("\nKiểm tra giá trị thiếu (Missing values):")
print(df.isnull().sum())

# --- 2. Thống kê mô tả ---
print("\n--- Bước 2: Thống kê mô tả ---")
desc = df.describe().T
desc['median'] = df.median()
print(desc[['mean', 'median', 'std', 'min', 'max']])

print("\nNHẬN XÉT: Nhìn vào dòng 'max' của dien_tich và gia, ta thấy giá trị cực đại lớn hơn rất nhiều")
print("so với trung bình (mean), dấu hiệu của các điểm ngoại lệ (Outliers).")

# --- 3. Vẽ Boxplot ---
print("\n--- Bước 3: Vẽ Boxplot ---")
plt.figure(figsize=(15, 5))
for i, col in enumerate(df.columns):
    plt.subplot(1, 3, i+1)
    sns.boxplot(y=df[col], color='skyblue')
    plt.title(f'Boxplot of {col}')
plt.tight_layout()
plt.show()

# --- 4. Vẽ Scatterplot ---
print("\n--- Bước 4: Vẽ Scatterplot ---")
plt.figure(figsize=(8, 6))
sns.scatterplot(data=df, x='dien_tich', y='gia', hue='so_phong', palette='viridis')
plt.title('Mối quan hệ Diện tích và Giá (Phát hiện điểm lạc lõng)')
plt.show()

# --- 5. Tính IQR ---
print("\n--- Bước 5 & 7: Xác định ngoại lệ theo IQR ---")
Q1 = df.quantile(0.25)
Q3 = df.quantile(0.75)
IQR = Q3 - Q1
outliers_iqr = ((df < (Q1 - 1.5 * IQR)) | (df > (Q3 + 1.5 * IQR))).any(axis=1)
print(f"Số lượng ngoại lệ phát hiện bằng IQR: {outliers_iqr.sum()}")

# --- 6. Tính Z-score ---
print("\n--- Bước 6 & 7: Xác định ngoại lệ theo Z-score ---")
z_scores = np.abs(stats.zscore(df.select_dtypes(include=[np.number])))
outliers_z = (z_scores > 3).any(axis=1)
print(f"Số lượng ngoại lệ phát hiện bằng Z-score (|Z| > 3): {outliers_z.sum()}")

# --- 8. Phân tích nguyên nhân ---
print("\n--- Bước 8: Phân tích nguyên nhân ---")
print("Dựa trên dữ liệu, điểm ngoại lệ (ví dụ: dien_tich=1000, gia=50000, so_phong=20)")
print("có thể là lỗi nhập liệu (thừa số 0) hoặc là biệt thự siêu lớn (đặc thù thực tế).")

# --- 9. Xử lý ngoại lệ (Sử dụng phương pháp loại bỏ) ---
print("\n--- Bước 9: Áp dụng xử lý (Loại bỏ các điểm Z-score > 3) ---")
df_cleaned = df[~outliers_z]
print(f"Số lượng dòng dữ liệu sau khi làm sạch: {df_cleaned.shape[0]}")

# --- 10. Vẽ lại Boxplot sau xử lý ---
print("\n--- Bước 10: Vẽ lại Boxplot sau xử lý ---")
plt.figure(figsize=(15, 5))
for i, col in enumerate(df_cleaned.columns):
    plt.subplot(1, 3, i+1)
    sns.boxplot(y=df_cleaned[col], color='lightgreen')
    plt.title(f'Cleaned {col}')
plt.tight_layout()
plt.show()

print("\nNHẬN XÉT: Sau khi xử lý, phạm vi biến thiên của dữ liệu đã thu hẹp lại,")
print("giúp biểu đồ không bị nén và các mô hình dự báo sau này sẽ ổn định hơn.")


